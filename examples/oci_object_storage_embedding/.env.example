# Example environment variables for this example
# Copy this to .env and fill in your actual values

COCOINDEX_DB=./cocoindex.db

# Postgres database address for cocoindex
POSTGRES_URL=postgres://cocoindex:cocoindex@localhost/cocoindex

# OCI Object Storage Configuration
OCI_NAMESPACE=your-tenancy-namespace
OCI_BUCKET=cocoindex-example-data

# Optional: only list objects under this prefix
OCI_PREFIX=markdown_files/

# Optional: OCI SDK config file + profile (defaults shown)
# OCI_CONFIG_FILE=~/.oci/config
# OCI_PROFILE=DEFAULT

# ---------------------------------------------------------------------------
# OCI Streaming (Kafka-compatible) — optional, enables live mode.
# When all four are set, the example subscribes to the stream and applies
# incremental updates on top of the initial scan.
# ---------------------------------------------------------------------------

# OCI_STREAMING_BOOTSTRAP_SERVERS=cell-1.streaming.us-ashburn-1.oci.oraclecloud.com:9092
# OCI_STREAMING_TOPIC=cocoindex-example-data-events
#
# OCI_STREAMING_USERNAME format: <tenancy-name>/<username>/<stream-pool-ocid>
#   - <tenancy-name>: plain tenancy name (e.g. "acme-corp"), NOT the tenancy OCID.
#     If your tenancy uses Identity Domains, prefix with the domain:
#     <tenancy-name>/<domain-name>/<username>/<stream-pool-ocid>
#   - <username>: plain IAM username (e.g. "alice@example.com"), NOT the user OCID.
#   - <stream-pool-ocid>: full OCID like "ocid1.streampool.oc1.iad.aaaa..." (yes, OCID).
# Find this exact string pre-formatted under: Streaming → Stream Pools → <pool>
#   → Kafka Connection Settings → "SASL Connection String".
# OCI_STREAMING_USERNAME=acme-corp/alice@example.com/ocid1.streampool.oc1.iad.aaaa...
#
# OCI_STREAMING_AUTH_TOKEN: a per-user "Auth Token" (not a password, not an API key).
# Generate via Console → Profile → My profile → Auth tokens → Generate token.
# OCI_STREAMING_AUTH_TOKEN=<your-streaming-auth-token>
#
# Free-form Kafka consumer group ID — pick any non-empty string, reuse it
# across runs to resume from the last committed offset. Distinct pipelines
# (e.g. different buckets / prefixes / environments) should use distinct
# group IDs. Bump (e.g. add a "-v2" suffix) to force a re-read from earliest.
# OCI_STREAMING_GROUP_ID=cocoindex-oci-object-storage-example

# Fallback to CPU for operations not supported by MPS on Mac.
# It's no-op for other platforms.
PYTORCH_ENABLE_MPS_FALLBACK=1
