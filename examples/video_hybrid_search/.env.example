# Copy to .env (main.py loads it). Everything here is optional.

# A Hugging Face token silences the "unauthenticated requests" warning and gives
# faster model downloads. Create one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Model overrides. Defaults: clip-vit-base-patch32 and whisper base.
# CLIP_MODEL=openai/clip-vit-large-patch14
# WHISPER_MODEL=tiny
