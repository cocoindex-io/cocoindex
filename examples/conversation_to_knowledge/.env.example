COCOINDEX_DB=./cocoindex.db
COCOINDEX_MAX_INFLIGHT_COMPONENTS=5

# Required
ASSEMBLYAI_API_KEY=...
OPENAI_API_KEY=sk-...

# SurrealDB connection (optional, shown with defaults)
SURREALDB_URL=ws://localhost:8787/rpc
SURREALDB_NS=cocoindex
SURREALDB_DB=yt_conversations
SURREALDB_USER=root
SURREALDB_PASS=root

# Input directory (optional, shown with default)
INPUT_DIR=./input

# Models (optional, shown with defaults)
LLM_MODEL=gpt-5.4
RESOLUTION_LLM_MODEL=gpt-4.1-mini
