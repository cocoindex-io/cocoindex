COCOINDEX_DB=./cocoindex.db

# Copy this file to .env before running the example.
# The example loads .env automatically.

# Use the Account identifier from Snowflake Account Details.
# Example format: ORGNAME-ACCOUNTNAME
SNOWFLAKE_ACCOUNT=your-account-identifier

# Use the Snowflake login name for the user.
SNOWFLAKE_USER=your-user

# This example uses password authentication.
SNOWFLAKE_PASSWORD=your-password

# Optional. Leave blank to use the user's default role.
# The role must be able to use the warehouse and create/manage the target table.
SNOWFLAKE_ROLE=

# Create the warehouse once before running the example; see README.md.
SNOWFLAKE_WAREHOUSE=COCOINDEX_DEMO_WH

# CocoIndex creates these objects when the example runs.
SNOWFLAKE_DATABASE=COCOINDEX_DEMO_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_TABLE=COCOINDEX_ORDERS
