# CocoIndex state database
COCOINDEX_DB=./cocoindex.db

# Kafka broker address
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka topic to consume from (must match csv_to_kafka producer)
KAFKA_TOPIC=cocoindex-example-csv-rows

# Kafka consumer group ID
KAFKA_GROUP_ID=kafka-to-lancedb

# SASL authentication (required for StreamNative and other managed Kafka services)
# Leave empty for local Kafka without authentication.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# LanceDB storage path
LANCEDB_URI=./lancedb_data
