COCOINDEX_DB=./cocoindex.db

# hn_trending_topics — environment template.
# Copy to .env (auto-loaded when you run the example): cp .env.example .env

# Postgres + pgvector target. Start a local one: docker compose -f ../../dev/postgres.yaml up -d
POSTGRES_URL=postgres://cocoindex:cocoindex@localhost/cocoindex

# LLM key for topic extraction. Default model is gemini/gemini-2.5-flash.
GEMINI_API_KEY=
# Optional: any litellm model id (then set the matching provider key).
# LLM_MODEL=gemini/gemini-2.5-flash
