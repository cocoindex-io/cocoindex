COCOINDEX_DB=./cocoindex.db

# gdrive_text_embedding — environment template.
# Copy to .env (auto-loaded when you run the example): cp .env.example .env

# Postgres + pgvector target. Start a local one: docker compose -f ../../dev/postgres.yaml up -d
POSTGRES_URL=postgres://cocoindex:cocoindex@localhost/cocoindex

# Google Drive: a service-account JSON key file, and the folder id(s) to index.
GOOGLE_SERVICE_ACCOUNT_CREDENTIAL=./service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_IDS=your_folder_id

# Fallback to CPU for operations not supported by MPS on Mac.
# It's no-op for other platforms.
PYTORCH_ENABLE_MPS_FALLBACK=1
