# pgvector-enabled Postgres
POSTGRES_URL=postgres://cocoindex:cocoindex@localhost/cocoindex

# Path to a Google Cloud service-account JSON key (share the Drive folder(s)
# with this service account's email).
GOOGLE_SERVICE_ACCOUNT_CREDENTIAL=/path/to/service-account.json

# Comma-separated Google Drive root folder ids to index (recursively).
GOOGLE_DRIVE_ROOT_FOLDER_IDS=folder_id_1,folder_id_2
