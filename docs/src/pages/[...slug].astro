---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import { docSlug, titleText } from '../consts';
import headings from '../docs-headings.json';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: docSlug(doc.id) },
    props: { doc },
  }));
}

type Props = { doc: CollectionEntry<'docs'> };
const { doc } = Astro.props as Props;
const { Content, headings: mdHeadings } = await render(doc);

const slug = docSlug(doc.id);
const rel = (doc as unknown as { filePath?: string }).filePath
  ?.split('/src/content/docs/')
  .pop();
const sourcePath = rel ?? `${doc.id}.md`;

// Curated headings override frontmatter. Titles may contain *asterisks*
// to italicize in coral (see src/consts.ts); plain metadata strips them.
const curated = (headings as Record<string, { title?: string; lede?: string }>)[slug];
const rawTitle: string =
  curated?.title ??
  (typeof doc.data.title === 'string' && doc.data.title.length > 0 ? doc.data.title : slug);
const title = rawTitle;
const metaTitle = titleText(rawTitle);
const description =
  curated?.lede ??
  (typeof doc.data.description === 'string' ? doc.data.description : undefined);
---

<DocsLayout
  title={metaTitle}
  titleMarkup={title}
  description={description}
  slug={slug}
  headings={mdHeadings}
  sourcePath={sourcePath}
>
  <Content />
</DocsLayout>
