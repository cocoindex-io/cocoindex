---
import { render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import { docSlug, titleText, pageUrl } from '../consts';
import { docStaticPaths, extractFaqEntries } from '../lib/raw-markdown';

export const getStaticPaths = docStaticPaths;

type Props = { doc: CollectionEntry<'docs'> };
const { doc } = Astro.props as Props;
const { Content, headings: mdHeadings } = await render(doc);

const slug = docSlug(doc.id);
const rel = (doc as unknown as { filePath?: string }).filePath
  ?.split('/src/content/docs/')
  .pop();
const sourcePath = rel ?? `${doc.id}.md`;

// Title may contain *asterisks* marking italic-coral segments
// (see src/consts.ts titleMarkup); plain metadata strips them.
const rawTitle: string =
  typeof doc.data.title === 'string' && doc.data.title.length > 0 ? doc.data.title : slug;
const title = rawTitle;
const metaTitle = titleText(rawTitle);
const description =
  typeof doc.data.description === 'string' ? doc.data.description : undefined;
const introMeta = doc.data.meta;

// FAQ pages (### question / answer prose) become FAQPage JSON-LD so the
// answers are eligible for Google's FAQ rich result — the same win the blog
// gets from its faq.json. Built from the page body; empty for every other doc.
const faqEntries = slug === 'faq' || slug.endsWith('/faq') ? extractFaqEntries(doc.body) : [];
const faqJsonLd =
  faqEntries.length > 0
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        url: pageUrl(slug),
        mainEntity: faqEntries.map((e) => ({
          '@type': 'Question',
          name: e.q,
          acceptedAnswer: { '@type': 'Answer', text: e.a },
        })),
      }]
    : [];
---

<DocsLayout
  title={metaTitle}
  titleMarkup={title}
  description={description}
  slug={slug}
  headings={mdHeadings}
  sourcePath={sourcePath}
  introMeta={introMeta}
  extraJsonLd={faqJsonLd}
>
  <Content />
</DocsLayout>
